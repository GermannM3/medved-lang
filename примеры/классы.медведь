# Пример 3: Классы и наследование
класс Животное {
    функция __ини__(имя, возраст) {
        сам.имя = имя
        сам.возраст = возраст
    }
    
    функция говорить() {
        возврат "..."
    }
    
    функция информация() {
        возврат "Я " + сам.имя + ", мне " + строка(сам.возраст) + " лет"
    }
}

класс Медведь наследует Животное {
    функция говорить() {
        возврат "Рррр! Я медведь!"
    }
    
    функция спать() {
        вывод сам.имя + " засыпает..."
    }
}

класс Волк наследует Животное {
    функция говорить() {
        возврат "Уууу! Я волк!"
    }
}

# Создаём экземпляры
пусть мишка = Медведь("Балу", 5)
пусть серый = Волк("Акела", 7)

вывод мишка.информация()
вывод мишка.говорить()
мишка.спать()

вывод серый.информация()
вывод серый.говорить()
