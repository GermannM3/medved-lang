# Пример программы на языке Медведь
# Это комментарий - он игнорируется интерпретатором

функция приветствие(имя):
    печать("Привет, " + имя + "! Добро пожаловать в язык Медведь!")
    возврат истина

функция сложить(а, б):
    результат = а + б
    возврат результат

функция факториал(n):
    если n <= 1:
        возврат 1
    иначе:
        возврат n * факториал(n - 1)

# Основная программа
приветствие("Медведь")

печать("2 + 3 = ", сложить(2, 3))
печать("Факториал 5 = ", факториал(5))

# Цикл пока
счётчик = 0
пока счётчик < 5:
    печать("Счётчик: ", счётчик)
    счётчик = счётчик + 1

# Цикл для
печать("Числа от 1 до 5:")
для i в [1, 2, 3, 4, 5]:
    печать(i)

# Условные операторы
число = 42
если число > 50:
    печать("Число больше 50")
иначе_если число < 10:
    печать("Число меньше 10")
иначе:
    печать("Число между 10 и 50")

печать("Программа завершена!")
