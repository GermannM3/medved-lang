# Пример 2: Фибоначчи
функция фибоначчи(n) {
    если n <= 1 {
        возврат n
    }
    
    пусть а = 0
    пусть б = 1
    
    пока n > 1 {
        пусть temp = а + б
        а = б
        б = temp
        n = n - 1
    }
    
    возврат б
}

# Вывод первых 10 чисел Фибоначчи
пусть i = 0
пока i < 10 {
    вывод "F(" + строка(i) + ") = " + строка(фибоначчи(i))
    i = i + 1
}
