# Пример 3: Простой веб-сервер
# Демонстрация работы с классами, маршрутизацией и HTTP

класс Запрос:
    функция __инициализация__(метод, путь, заголовки, тело):
        сам.метод = метод
        сам.путь = путь
        сам.заголовки = заголовки
        сам.тело = тело

класс Ответ:
    функция __инициализация__(код, заголовки, тело):
        сам.код = код
        сам.заголовки = заголовки
        сам.тело = тело
    
    функция в_строку():
        строка = "HTTP/1.1 " + сам.код + "\n"
        для ключ в сам.заголовки:
            строка = строка + ключ + ": " + сам.заголовки[ключ] + "\n"
        строка = строка + "\n" + сам.тело
        вернуть строку

класс Маршрут:
    функция __инициализация__(путь, обработчик):
        сам.путь = путь
        сам.обработчик = обработчик

класс ВебСервер:
    функция __инициализация__(хост, порт):
        сам.хост = хост
        сам.порт = порт
        сам.маршруты = []
        сам.работающий = ложь
    
    функция добавить_маршрут(путь, обработчик):
        маршрут = Маршрут(путь, обработчик)
        сам.маршруты.добавить(маршрут)
        вывод "Добавлен маршрут: " + путь
    
    функция найти_маршрут(путь):
        для маршрут в сам.маршруты:
            если маршрут.путь == путь:
                вернуть маршрут.обработчик
        вернуть пусто
    
    функция обработать(запрос):
        обработчик = сам.найти_маршрут(запрос.путь)
        
        если обработчик != пусто:
            результат = обработчик(запрос)
            вернуть результат
        иначе:
            вернуть Ответ("404 Не найдено", {"Content-Type": "text/html"}, "<h1>404 - Страница не найдена</h1>")
    
    функция запустить():
        сам.работающий = истина
        вывод "Сервер запущен на " + сам.хост + ":" + сам.порт
        
        # Симуляция обработки запросов
        пока сам.работающий:
            # В реальности здесь был бы цикл принятия соединений
            вывод "Ожидание запросов... (Ctrl+C для остановки)"
            прервать  # Для демо сразу выходим
    
    функция остановить():
        сам.работающий = ложь
        вывод "Сервер остановлен"

# Обработчики страниц
функция главная_страница(запрос):
    html = """
    <!DOCTYPE html>
    <html>
    <head>
        <title>Медведь - Веб Сервер</title>
        <style>
            body { font-family: Arial; max-width: 800px; margin: 50px auto; }
            h1 { color: #8B4513; }
            .feature { background: #f5f5f5; padding: 15px; margin: 10px 0; border-radius: 5px; }
        </style>
    </head>
    <body>
        <h1>🐻 Добро пожаловать на сервер Медведь!</h1>
        <p>Это демонстрация веб-сервера, написанного на языке Медведь.</p>
        
        <div class="feature">
            <h2>Возможности:</h2>
            <ul>
                <li>100% кириллический синтаксис</li>
                <li>Объектно-ориентированное программирование</li>
                <li>Маршрутизация запросов</li>
                <li>Работа с HTML и CSS</li>
            </ul>
        </div>
        
        <p><a href="/о-нас">Узнать больше о проекте</a></p>
        <p><a href="/api/статус">API статуса</a></p>
    </body>
    </html>
    """
    вернуть Ответ("200 OK", {"Content-Type": "text/html"}, html)

функция страница_о_нас(запрос):
    html = """
    <!DOCTYPE html>
    <html>
    <head>
        <title>О проекте Медведь</title>
    </head>
    <body>
        <h1>О языке Медведь</h1>
        <p>Медведь — это полноценный язык программирования на кириллице.</p>
        <p>Он создан для разработчиков, которые хотят писать код на родном языке.</p>
        <p><a href="/">← На главную</a></p>
    </body>
    </html>
    """
    вернуть Ответ("200 OK", {"Content-Type": "text/html"}, html)

функция api_статус(запрос):
    json = '{"статус": "работает", "версия": "1.0.0", "язык": "Медведь"}'
    вернуть Ответ("200 OK", {"Content-Type": "application/json"}, json)

функция главная():
    вывод "=== Запуск Веб Сервера на Медведе ==="
    
    # Создаём сервер
    сервер = ВебСервер("localhost", 8080)
    
    # Добавляем маршруты
    сервер.добавить_маршрут("/", главная_страница)
    сервер.добавить_маршрут("/о-нас", страница_о_нас)
    сервер.добавить_маршрут("/api/статус", api_статус)
    
    # Симулируем обработку запросов для демонстрации
    вывод "\n=== Тестирование маршрутов ==="
    
    тестовые_запросы = [
        Запрос("GET", "/", {}, ""),
        Запрос("GET", "/о-нас", {}, ""),
        Запрос("GET", "/api/статус", {}, ""),
        Запрос("GET", "/не-существует", {}, "")
    ]
    
    для запрос в тестовые_запросы:
        вывод "\nЗапрос: " + запрос.метод + " " + запрос.путь
        ответ = сервер.обработать(запрос)
        вывод "Ответ: " + ответ.код
        вывод "Тело (первые 50 символов): " + ответ.тело[0:50] + "..."
    
    вывод "\n=== Демонстрация завершена ==="
    вывод "Для реального запуска раскомментируйте: сервер.запустить()"

главная()
