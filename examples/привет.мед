# Программа на языке Медведь

печать("Привет, Мир!")
печать("Добро пожаловать в язык Медведь!")

имя = "Медведь"
версия = 1.0

печать("Язык: " + имя)
печать("Версия: " + строка(версия))

функция приветствовать(кто):
    печать("Привет, " + кто + "!")
    возврат "ok"

приветствовать("Мир")
приветствовать("Разработчик")

число = 42
если число > 40:
    печать("Число больше 40")

для i в диапазон(5):
    печать("Считаем: " + строка(i))

массив = [1, 2, 3, 4, 5]
печать("Первый элемент: " + строка(массив[0]))
печать("Длина массива: " + строка(длина(массив)))

функция факториал(n):
    если n <= 1:
        возврат 1
    возврат n * факториал(n - 1)

печать("Факториал 5: " + строка(факториал(5)))
печать("Программа завершена!")
