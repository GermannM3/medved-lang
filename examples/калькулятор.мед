# Пример 2: Умный калькулятор
# Демонстрация условий, циклов, рекурсии и функций

функция сложить(а, б):
    вернуть а + б

функция вычесть(а, б):
    вернуть а - б

функция умножить(а, б):
    вернуть а * б

функция разделить(а, б):
    если б == 0:
        вывод "Ошибка: деление на ноль!"
        вернуть 0
    иначе:
        вернуть а / б

функция факториал(число):
    # Рекурсивная функция для вычисления факториала
    если число <= 1:
        вернуть 1
    иначе:
        вернуть число * факториал(число - 1)

функция возвести_в_степень(основание, степень):
    результат = 1
    для i от 0 до степень:
        если i == 0:
            продолжить
        результат = результат * основание
    вернуть результат

функция главная():
    вывод "=== Умный Калькулятор на Медведе ==="
    
    # Базовые операции
    а = 15
    б = 4
    
    вывод "Числа: " + а + " и " + б
    вывод "Сложение: " + сложить(а, б)
    вывод "Вычитание: " + вычесть(а, б)
    вывод "Умножение: " + умножить(а, б)
    вывод "Деление: " + разделить(а, б)
    
    # Факториал
    вывод "\nФакториалы:"
    для n от 1 до 6:
        факт = факториал(n)
        вывод "  " + n + "! = " + факт
    
    # Степени
    вывод "\nСтепени двойки:"
    для степень от 0 до 10:
        значение = возвести_в_степень(2, степень)
        вывод "  2^" + степень + " = " + значение
    
    # Интерактивный режим (симуляция)
    вывод "\n=== Тестовые вычисления ==="
    
    результаты = []
    для x от 1 до 5:
        у = сложить(умножить(x, 2), 10)
        результаты.добавить(у)
        вывод "x=" + x + " => y=" + у
    
    вывод "\nВсе результаты: " + результаты
    
    вывод "\n=== Калькулятор завершил работу ==="

главная()
